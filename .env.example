# Copy to `.env` or override with `.env.local` (gitignored via *.local).
# Vite loads: .env → .env.local → .env.[mode] → .env.[mode].local (later wins).
# After changing VITE_* vars, stop and restart `npm run dev` (Vite only reads env at startup).

# ── Option A: Local Vite + local Laravel (use Vite proxy, no CORS) ───────────
# VITE_API_URL=/api/v1
# VITE_APP_URL=http://localhost:5173
# VITE_IMAGE_BASE_URL=http://127.0.0.1:8000/storage

# ── Option B: Local Vite + production API (your case) ───────────────────────
VITE_API_URL=https://api.pyonea.com/api/v1
VITE_APP_URL=http://localhost:5173
VITE_IMAGE_BASE_URL=https://api.pyonea.com/storage

VITE_DEFAULT_PRODUCT_IMAGE=/placeholder-product.png

VITE_APP_NAME=Pyonea
VITE_APP_ENV=development

VITE_GA_MEASUREMENT_ID=
VITE_RECAPTCHA_SITE_KEY=

# Sanctum cookies to API: default is ON. Set to false for Bearer-only (no credentialed CORS).
# VITE_API_WITH_CREDENTIALS=false
